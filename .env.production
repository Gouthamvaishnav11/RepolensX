APP_NAME=RepoLens X
APP_ENV=production
DEBUG=false
SECRET_KEY=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING
ALLOWED_ORIGINS=https://repolens.ai,https://www.repolens.ai

POSTGRES_DB=repolens
POSTGRES_USER=repolens
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://repolens:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/repolens

REDIS_URL=redis://redis:6379/0
CHROMA_HOST=chromadb
CHROMA_PORT=8000

OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_CALLBACK_URL=https://repolens.ai/auth/callback

JWT_SECRET_KEY=CHANGE_THIS_ANOTHER_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

FRONTEND_URL=https://repolens.ai
